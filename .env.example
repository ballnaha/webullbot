# Webull Trading Bot Configuration

# Trading Mode: LOCAL_PAPER (offline simulation), WEBULL_PAPER (online simulation), WEBULL_LIVE (live trading), WEBULL_OFFICIAL (official OpenAPI)
TRADE_MODE=LOCAL_PAPER

# --- Webull Unofficial API Credentials ---
WEBULL_USERNAME=your_email_or_phone_number
WEBULL_PASSWORD=your_webull_password
WEBULL_TRADE_PIN=your_6_digit_trade_pin
WEBULL_DEVICE_NAME=PythonBot

# --- Webull Official OpenAPI Credentials (If applicable) ---
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_API_ENDPOINT=
WEBULL_API_REGION=us


# --- Trading Strategy Parameters ---
# Comma-separated list of stock tickers to monitor
DEFAULT_SYMBOLS=AAPL,MSFT,TSLA,NVDA

# Default quantity per trade
TRADE_QUANTITY=1

# Run Interval in seconds (e.g. 60 seconds = 1 minute check)
INTERVAL=60

# Candlestick bar period (options: m1, m5, m15, m30, h1, d)
# Note: 'd' for daily bars, 'm5' for 5-minute bars
CANDLE_PERIOD=d

# Initial simulation cash for LOCAL_PAPER mode (USD and HKD)
SIMULATED_INITIAL_CASH=10000.0
SIMULATED_INITIAL_CASH_HKD=78000.0
USD_HKD_RATE=7.8

# Trading strategies for US and HK bots (options: sma, rsi, hybrid)
STRATEGY_US=sma
STRATEGY_HK=rsi
HK_SMA_FAST_PERIOD=20
HK_SMA_SLOW_PERIOD=50


# --- Hong Kong Stock Settings & Limits ---
# Default quantity per trade for HK stocks (shares)
TRADE_QUANTITY_HK=100
HK_TRADE_BUDGET_HKD=2000.0
HK_ETF_BUDGET_HKD=1000.0
HK_DEFAULT_BOARD_LOT=100

# Limit how many slots can be bought (maximum slots to hold per symbol)
HK_MAX_SLOTS=1

# Maximum price the bot is allowed to buy at (HKD)
HK_MAX_PRICE_PER_SLOT=999999.0

# Maximum quantity allowed to buy per slot (shares)
HK_MAX_QTY_PER_SLOT=100

# HK scanner signals filtering price limit and operator (le = <=, ge = >=)
HK_FILTER_PRICE_LIMIT=20.0
HK_FILTER_PRICE_OPERATOR=le

# Local paper execution costs
PAPER_SLIPPAGE_BPS=5.0
PAPER_FEE_HK_RATE=0.0012
PAPER_STRICT_MARKET_RULES=TRUE

# HK inverse ETFs are portfolio hedges by default, not standalone short bets.
HK_ALLOW_NAKED_INVERSE=FALSE
HK_HEDGE_RATIO=0.5
HK_ETF_STRATEGY=trend_cash_3067
HK_LONG_ETF_SYMBOL=3067.HK
HK_ETF_TREND_FAST=20
HK_ETF_TREND_SLOW=50
HK_ETF_MOMENTUM_PERIOD=20
HK_ETF_REBALANCE_BARS=5

